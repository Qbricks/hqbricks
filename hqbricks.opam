  "ppx_deriving"
  "ppx_deriving_yojson"
  "zarith"
  "mlmpfr"
  "cmdliner" {= "1.3.0"}
  "alcotest" {with-test}
  "bechamel" {with-test}
  "bechamel-notty" {with-test}
]
